# ── AI Product Similarity (marketplace backend → Python FastAPI) ─────────────
# Copy these lines into markeetplace-backed/.env

# Enable/disable AI hooks and search proxy
AI_IMAGE_SEARCH_ENABLED=true

# Python FastAPI service (image-ai-search/app.py) — default port 9000
AI_SERVICE_URL=http://127.0.0.1:9000

# Path to image-ai-search folder (build_index.py + indexes/)
AI_IMAGE_SEARCH_DIR=D:\Arrak consulting\image-ai-search

# Product images folder — canonical catalog folder is uploads/products (NOT uploads/images/products)
# Leave unset to default to <backend>/uploads/products
# AI_PRODUCT_IMAGES_DIR=uploads/products

# Index build tuning (optional — backend passes these into build_index --fast)
# AI_BUILD_BATCH_SIZE=128
# AI_EMBEDDING_BATCH_SIZE=64
# AI_EMBEDDED_MAX_SIDE=352
# AI_OMP_THREADS=4

# Python executable — omit to auto-detect image-ai-search/.venv or venv
# AI_PYTHON_BIN=D:\Arrak consulting\image-ai-search\.venv\Scripts\python.exe

# Debounce before incremental index after uploads (milliseconds)
AI_INDEX_DEBOUNCE_MS=45000

# ── Python image-ai-search/.env ──────────────────────────────────────────────
# IMAGE_ROOT=D:\Arrak consulting\markeetplace-backed\uploads\products
# PORT=9000
#
# Faster rebuilds (lower accuracy): smaller CLIP model
# CLIP_MODEL=ViT-B-32
# CLIP_PRETRAINED=laion400m_e32

# ── Frontend ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_API=http://localhost:5000
